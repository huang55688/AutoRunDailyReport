@{
    ViewData["Title"] = "In Line Test byLine";
}

<style>
    .inline-test-page .chart-mode-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        margin-top: 18px;
    }

    .inline-test-page .chart-mode-buttons {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .inline-test-page .chart-mode-button {
        min-width: 116px;
        font-weight: 700;
    }

        .inline-test-page .chart-mode-button.active {
            background-color: #1a237e;
            border-color: #1a237e;
            color: #fff;
            box-shadow: 0 6px 14px rgba(26, 35, 126, 0.18);
        }

    .inline-test-page .chart-mode-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #24324a;
    }

    .inline-test-page .chart-mode-hint {
        color: #6c757d;
        font-size: 0.9rem;
    }

    .inline-test-page .chart-note {
        line-height: 1.7;
    }
</style>

<div class="container-fluid inline-test-page py-3">
    <h4 class="mb-3">&lt;In Line Test byLine&gt;</h4>

    <!-- 篩選器 -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small text-muted">起始日期</label>
                    <input type="date" id="dateFrom" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">結束日期</label>
                    <input type="date" id="dateTo" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">KF Phase</label>
                    <select id="kfPhaseSelect" class="form-select form-select-sm">
                        <option value="">(全部)</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">樓別 (Layout)</label>
                    <select id="layoutSelect" class="form-select form-select-sm">
                        <option value="">(全部)</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button id="btnQuery" class="btn btn-primary btn-sm w-100">查詢</button>
                </div>
            </div>
        </div>
    </div>

    <!-- 圖表模式切換 -->
    <div class="chart-mode-toolbar mb-3">
        <div>
            <span id="chartModeTitle" class="chart-mode-title"></span>
            <div id="chartModeHint" class="chart-mode-hint"></div>
        </div>
        <div class="chart-mode-buttons">
            <button class="btn btn-outline-primary btn-sm chart-mode-button" data-mode="stacked">堆疊圖</button>
            <button class="btn btn-outline-primary btn-sm chart-mode-button" data-mode="ok">只看 OK</button>
            <button class="btn btn-outline-primary btn-sm chart-mode-button" data-mode="ng">只看 NG</button>
        </div>
    </div>

    <!-- 圖表 -->
    <div class="card">
        <div class="card-body">
            <div style="position:relative; height:520px;">
                <canvas id="inlineChart"></canvas>
            </div>
        </div>
    </div>

    <div class="mt-3 small text-muted chart-note">
        <div>藍線代表累計總數，會貼著堆疊長條圖的頂部並用線連起來。</div>
        <div>綠色數字代表 OK 累計、紅色數字代表 NG 累計，數字會顯示在對應顏色的長條圖內。</div>
    </div>

    <!-- 未完成線別清單 -->
    <div class="card mt-3">
        <div class="card-header bg-danger bg-opacity-10 d-flex justify-content-between align-items-center">
            <span class="fw-bold text-danger">⚠ 未完成確認的線別清單（按月份分區）</span>
            <span id="incompleteCount" class="badge bg-danger">0</span>
        </div>
        <div class="card-body p-0" id="incompleteContainer">
            <div class="text-center text-muted py-3">載入中...</div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
    <script>
        Chart.register(ChartDataLabels);

        let chart = null;
        let currentMode = 'stacked';
        let latestChartData = null;

        const modeMeta = {
            stacked: {
                title: 'OK + NG 累計堆疊圖',
                hint: '綠色與紅色數字顯示在長條圖內，藍線顯示累計總數。'
            },
            ok: {
                title: '只看 OK 累計長條圖',
                hint: '只顯示 OK（已確認）累計數據。'
            },
            ng: {
                title: '只看 NG 累計長條圖',
                hint: '只顯示 NG（差異）累計數據。'
            }
        };

        const today = new Date();
        const defFrom = new Date(today.getFullYear(), today.getMonth(), 1);
        const defTo = new Date(today.getFullYear(), today.getMonth() + 3, 0);

        function toLocalDateStr(d) {
            const y = d.getFullYear();
            const m = String(d.getMonth() + 1).padStart(2, '0');
            const day = String(d.getDate()).padStart(2, '0');
            return `${y}-${m}-${day}`;
        }

        function getBarLabelOptions(color) {
            return {
                display(context) {
                    return (context.dataset.data[context.dataIndex] ?? 0) > 0;
                },
                color,
                anchor: 'center',
                align: 'center',
                clamp: true,
                font: { weight: 'bold', size: 12 }
            };
        }

        function getLineLabelOptions() {
            return {
                display(context) {
                    return (context.dataset.data[context.dataIndex] ?? 0) > 0;
                },
                color: '#1a237e',
                backgroundColor: 'rgba(255, 255, 255, 0.92)',
                borderRadius: 999,
                padding: { top: 4, right: 8, bottom: 4, left: 8 },
                anchor: 'end',
                align: 'top',
                offset: 6,
                font: { weight: 'bold', size: 12 }
            };
        }

        function getDatasets(data, mode) {
            if (mode === 'ok') {
                return [{
                    type: 'bar',
                    label: 'OK（已確認）',
                    data: data.okData,
                    backgroundColor: 'rgba(75, 192, 120, 0.65)',
                    borderColor: 'rgba(60, 160, 100, 0.95)',
                    borderWidth: 1,
                    borderRadius: 6,
                    datalabels: getBarLabelOptions('#1f6b44')
                }];
            }

            if (mode === 'ng') {
                return [{
                    type: 'bar',
                    label: 'NG（差異）',
                    data: data.ngData,
                    backgroundColor: 'rgba(255, 99, 132, 0.45)',
                    borderColor: 'rgba(214, 74, 113, 0.95)',
                    borderWidth: 1,
                    borderRadius: 6,
                    datalabels: getBarLabelOptions('#b33d57')
                }];
            }

            return [
                {
                    type: 'bar',
                    label: 'OK（已確認）',
                    data: data.okData,
                    backgroundColor: 'rgba(75, 192, 120, 0.65)',
                    borderColor: 'rgba(60, 160, 100, 0.95)',
                    borderWidth: 1,
                    borderRadius: 6,
                    stack: 'summary',
                    datalabels: getBarLabelOptions('#1f6b44')
                },
                {
                    type: 'bar',
                    label: 'NG（差異）',
                    data: data.ngData,
                    backgroundColor: 'rgba(255, 99, 132, 0.45)',
                    borderColor: 'rgba(214, 74, 113, 0.95)',
                    borderWidth: 1,
                    borderRadius: 6,
                    stack: 'summary',
                    datalabels: getBarLabelOptions('#b33d57')
                },
                {
                    type: 'line',
                    label: '累計',
                    data: data.totalData,
                    borderColor: '#1a237e',
                    backgroundColor: '#1a237e',
                    borderWidth: 3,
                    pointRadius: 5,
                    pointHoverRadius: 6,
                    pointBackgroundColor: '#1a237e',
                    pointBorderColor: '#1a237e',
                    tension: 0.25,
                    fill: false,
                    datalabels: getLineLabelOptions()
                }
            ];
        }

        function getChartOptions(mode) {
            const stacked = mode === 'stacked';
            const yAxisTitle = mode === 'ok' ? 'OK 累計'
                             : mode === 'ng' ? 'NG 累計'
                             : 'OK / NG 累計';

            return {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { usePointStyle: true, padding: 20 }
                    },
                    tooltip: {
                        callbacks: {
                            title(items) { return items[0].label; }
                        }
                    }
                },
                scales: {
                    x: { stacked, grid: { display: false } },
                    y: { beginAtZero: true, stacked, title: { display: true, text: yAxisTitle } }
                }
            };
        }

        function updateModeUi() {
            document.querySelectorAll('.chart-mode-button').forEach(btn => {
                btn.classList.toggle('active', btn.dataset.mode === currentMode);
            });
            const meta = modeMeta[currentMode];
            document.getElementById('chartModeTitle').textContent = meta.title;
            document.getElementById('chartModeHint').textContent = meta.hint;
        }

        function renderChart() {
            if (!latestChartData) return;
            const ctx = document.getElementById('inlineChart').getContext('2d');
            if (chart) chart.destroy();
            chart = new Chart(ctx, {
                data: {
                    labels: latestChartData.labels,
                    datasets: getDatasets(latestChartData, currentMode)
                },
                options: getChartOptions(currentMode)
            });
        }

        function buildQueryParams() {
            const from = document.getElementById('dateFrom').value;
            const to = document.getElementById('dateTo').value;
            const kfPhase = document.getElementById('kfPhaseSelect').value;
            const layout = document.getElementById('layoutSelect').value;

            const params = new URLSearchParams();
            if (from) params.set('from', from);
            if (to) params.set('to', to);
            if (kfPhase) params.set('kfPhase', kfPhase);
            if (layout) params.set('layout', layout);
            return params;
        }

        async function loadFilters() {
            try {
                const res = await fetch('/api/chart/filters');
                if (!res.ok) return;
                const data = await res.json();

                const phaseSel = document.getElementById('kfPhaseSelect');
                data.phases.forEach(p => {
                    const opt = document.createElement('option');
                    opt.value = p;
                    opt.textContent = p;
                    phaseSel.appendChild(opt);
                });

                const layoutSel = document.getElementById('layoutSelect');
                data.layouts.forEach(s => {
                    const opt = document.createElement('option');
                    opt.value = s;
                    opt.textContent = s;
                    layoutSel.appendChild(opt);
                });
            } catch (_) { }
        }

        async function loadChart() {
            const params = buildQueryParams();
            const res = await fetch(`/api/chart/inline-test?${params}`);
            if (!res.ok) return;
            latestChartData = await res.json();
            renderChart();
        }

        async function loadIncompleteLines() {
            const params = buildQueryParams();
            const container = document.getElementById('incompleteContainer');
            const badge = document.getElementById('incompleteCount');

            try {
                const res = await fetch(`/api/chart/inline-test/incomplete?${params}`);
                if (!res.ok) {
                    container.innerHTML = '<div class="text-center text-muted py-3">載入失敗</div>';
                    return;
                }
                const data = await res.json();
                badge.textContent = data.totalCount;

                if (data.totalCount === 0) {
                    container.innerHTML = '<div class="text-center text-success py-3">🎉 全部已完成確認！</div>';
                    return;
                }

                let html = '';
                data.groups.forEach(group => {
                    html += `
                        <div class="border-bottom">
                            <div class="bg-light px-3 py-2 d-flex justify-content-between align-items-center"
                                 style="cursor:pointer;"
                                 onclick="this.nextElementSibling.classList.toggle('d-none')">
                                <span class="fw-semibold">📅 ${group.month}</span>
                                <span class="badge bg-secondary">${group.count} 筆未完成</span>
                            </div>
                            <div>
                                <table class="table table-sm table-hover mb-0 align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width:50px">#</th>
                                            <th>MESMachineName</th>
                                            <th>KF Phase</th>
                                            <th>Layout</th>
                                            <th>InLineTest 日期</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        ${group.items.map((item, idx) => `
                                            <tr>
                                                <td class="text-muted">${idx + 1}</td>
                                                <td><code>${item.machineName}</code></td>
                                                <td>${item.kfPhase || '-'}</td>
                                                <td>${item.layout || '-'}</td>
                                                <td>${item.inlineTestDate}</td>
                                            </tr>
                                        `).join('')}
                                    </tbody>
                                </table>
                            </div>
                        </div>`;
                });
                container.innerHTML = html;
            } catch (_) {
                container.innerHTML = '<div class="text-center text-muted py-3">載入失敗</div>';
            }
        }

        async function loadAll() {
            await Promise.all([loadChart(), loadIncompleteLines()]);
        }

        // 初始化
        document.getElementById('dateFrom').value = toLocalDateStr(defFrom);
        document.getElementById('dateTo').value = toLocalDateStr(defTo);

        document.getElementById('btnQuery').addEventListener('click', loadAll);

        document.querySelectorAll('.chart-mode-button').forEach(button => {
            button.addEventListener('click', () => {
                currentMode = button.dataset.mode;
                updateModeUi();
                renderChart();
            });
        });

        updateModeUi();
        loadFilters().then(loadAll);
    </script>
}