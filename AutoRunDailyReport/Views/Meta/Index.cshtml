@model IEnumerable<AutoRunDailyReport.Models.MesMachinesMetaDto>
@using System.Globalization
@{
    ViewData["Title"] = "機台資料管理";
    var culture = CultureInfo.GetCultureInfo("zh-TW");
    var items = Model?.ToList() ?? new List<AutoRunDailyReport.Models.MesMachinesMetaDto>();
    var currentSearch = ViewBag.Search as string ?? string.Empty;
    var futureDeadline = ViewBag.FutureDeadline is bool enabled && enabled;
}
@functions {
    public string DisplayOrDash(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    public bool HasMachineDetail(AutoRunDailyReport.Models.MesMachinesMetaDto item)
    {
        return !string.IsNullOrWhiteSpace(item.MESMachineNoString)
            || (item.SyncDetails?.Any() ?? false);
    }

    public string GetDeadlineBadgeClass(DateTime? deadline)
    {
        if (!deadline.HasValue)
            return "meta-badge meta-badge-empty";

        var daysLeft = (deadline.Value.Date - DateTime.Today).Days;
        if (daysLeft < 0)
            return "meta-badge meta-badge-overdue";
        if (daysLeft <= 7)
            return "meta-badge meta-badge-urgent";
        return "meta-badge meta-badge-safe";
    }
}

<link rel="stylesheet" href="~/css/meta.css" asp-append-version="true" />

<div class="container-fluid meta-page py-4">
    <div class="meta-page-header mb-4">
        <div class="meta-title-wrap">
            <span class="meta-title">機台資料管理</span>
        </div>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="meta-alert meta-alert-success mb-3">@success</div>
    }

    @if (ViewBag.Warning is string warning)
    {
        <div class="meta-alert meta-alert-warning mb-3">@warning</div>
    }

    <div class="meta-tools mb-3">
        <div class="meta-toolbar">
            <form asp-action="Index" method="get" class="meta-search-form">
                <label for="meta-search" class="meta-search-label">搜尋</label>
                <input
                    id="meta-search"
                    type="text"
                    name="search"
                    value="@currentSearch"
                    class="form-control meta-search-input"
                    placeholder="搜尋 Line 或 MESMachineName" />
                @if (futureDeadline)
                {
                    <input type="hidden" name="futureDeadline" value="true" />
                }
                <button type="submit" class="btn meta-primary-button meta-toolbar-button">搜尋</button>
                @if (!string.IsNullOrWhiteSpace(currentSearch) || futureDeadline)
                {
                    <a asp-action="Index" class="btn meta-secondary-button meta-toolbar-button">清除</a>
                }
            </form>

            <div class="meta-toolbar-actions">
                <a
                    asp-action="Index"
                    asp-route-search="@currentSearch"
                    asp-route-futureDeadline="@(futureDeadline ? "false" : "true")"
                    class="btn meta-deadline-sort-button @(futureDeadline ? "is-active" : string.Empty)">
                    未來DeadLine
                </a>
            </div>
        </div>
    </div>

    <div class="meta-table-shell">
        <div class="meta-table-wrap">
            <div class="table-responsive">
                <table class="table meta-table mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>MESMachineName</th>
                            <th>MESMachineNo_String</th>
                            <th>Line</th>
                            <th>1A Deadline</th>
                            <th>State</th>
                            <th>AIOT Owner</th>
                            <th>Owner</th>
                            <th>Test Status</th>
                            <th>Schedule</th>
                            <th>最後更新</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (items.Any())
                        {
                            foreach (var item in items)
                            {
                                <tr>
                                    <td class="meta-line-cell">@item.MESMachineName</td>
                                    <td class="meta-machine-code-cell">
                                        @if (HasMachineDetail(item))
                                        {
                                            <details class="meta-machine-detail">
                                                <summary class="meta-machine-detail-toggle">
                                                    <span class="meta-machine-code-text">@DisplayOrDash(item.MESMachineNoString)</span>
                                                </summary>

                                                <div class="meta-machine-detail-panel">
                                                    @if (item.SyncDetails.Any())
                                                    {
                                                        <div class="meta-machine-detail-list">
                                                            @foreach (var detail in item.SyncDetails)
                                                            {
                                                                <div class="meta-machine-detail-item">
                                                                    <div class="meta-machine-detail-row">
                                                                        <span class="meta-machine-detail-label">MESSubEQNo_String</span>
                                                                        <span class="meta-machine-detail-value">@DisplayOrDash(detail.MESSubEQNoString)</span>
                                                                    </div>
                                                                    <div class="meta-machine-detail-row">
                                                                        <span class="meta-machine-detail-label">Vendor</span>
                                                                        <span class="meta-machine-detail-value">@DisplayOrDash(detail.Vendor)</span>
                                                                    </div>
                                                                    <div class="meta-machine-detail-row">
                                                                        <span class="meta-machine-detail-label">IP</span>
                                                                        <span class="meta-machine-detail-value">@DisplayOrDash(detail.Ip)</span>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="meta-machine-detail-empty">目前沒有更多同步資料。</div>
                                                    }
                                                </div>
                                            </details>
                                        }
                                        else
                                        {
                                            <span class="meta-machine-code-empty">-</span>
                                        }
                                    </td>
                                    <td>@DisplayOrDash(item.Line)</td>
                                    <td class="text-nowrap">
                                        @if (item.FirstADeadline.HasValue)
                                        {
                                            <span class="@GetDeadlineBadgeClass(item.FirstADeadline)">
                                                @item.FirstADeadline.Value.ToString("yyyy/MM/dd", culture)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="meta-badge meta-badge-empty">-</span>
                                        }
                                    </td>
                                    <td>@DisplayOrDash(item.State)</td>
                                    <td>@DisplayOrDash(item.AiotOwner)</td>
                                    <td>@DisplayOrDash(item.Owner)</td>
                                    <td>@DisplayOrDash(item.TestStatus)</td>
                                    <td>@DisplayOrDash(item.Schedule)</td>
                                    <td class="meta-date-cell">@(item.UpdatedAt?.ToString("yyyy/MM/dd HH:mm") ?? "-")</td>
                                    <td class="meta-action-cell">
                                        <a asp-action="Edit" asp-route-machineName="@item.MESMachineName" class="btn meta-edit-button">編輯</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="11" class="meta-empty-state">目前沒有任何機台資料。</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
