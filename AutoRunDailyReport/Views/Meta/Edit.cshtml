@model AutoRunDailyReport.Models.MesMachinesMetaDto
@using System.Globalization
@{
    ViewData["Title"] = $"編輯機台：{Model.MESMachineName}";
    var culture = CultureInfo.GetCultureInfo("zh-TW");
    var today = DateTime.Today;
    int? daysLeft = Model.FirstADeadline.HasValue
        ? (Model.FirstADeadline.Value.Date - today).Days
        : null;

    var deadlineClass = !Model.FirstADeadline.HasValue
        ? "meta-badge meta-badge-empty"
        : daysLeft < 0
            ? "meta-badge meta-badge-overdue"
            : daysLeft <= 7
                ? "meta-badge meta-badge-urgent"
                : "meta-badge meta-badge-safe";

    var deadlineHint = !daysLeft.HasValue
        ? "尚未產生"
        : daysLeft.Value < 0
            ? $"已逾期 {-daysLeft.Value} 天"
            : daysLeft.Value == 0
                ? "今天到期"
                : $"剩 {daysLeft.Value} 天";
}

<link rel="stylesheet" href="~/css/meta.css" asp-append-version="true" />

<div class="container-fluid meta-page py-4">
    <div class="meta-edit-shell">
        <div class="d-flex align-items-center mb-4 gap-3 flex-wrap">
            <a asp-action="Index" class="meta-back-link">返回列表</a>
            <h3 class="mb-0 meta-edit-title">@Model.MESMachineName</h3>
        </div>

        <div class="meta-deadline-panel mb-4">
            <div class="meta-deadline-label">1A Deadline</div>
            <div class="d-flex align-items-center gap-3 flex-wrap">
                @if (Model.FirstADeadline.HasValue)
                {
                    <span class="@deadlineClass">@Model.FirstADeadline.Value.ToString("yyyy/MM/dd", culture)</span>
                    <span class="meta-deadline-hint">@deadlineHint</span>
                }
                else
                {
                    <span class="@deadlineClass">尚未產生</span>
                }
            </div>
        </div>

        <form asp-action="Edit" method="post" class="meta-form-shell">
            <input type="hidden" asp-for="MESMachineName" />
            <input type="hidden" asp-for="Line" />

            <div class="row g-3">
                <div class="col-sm-6">
                    <label asp-for="State" class="form-label meta-form-label">State</label>
                    <input asp-for="State" class="form-control meta-input" placeholder="請輸入狀態" />
                </div>

                <div class="col-sm-6">
                    <label asp-for="TestStatus" class="form-label meta-form-label">Test Status</label>
                    <input asp-for="TestStatus" class="form-control meta-input" placeholder="請輸入測試狀態" />
                </div>

                <div class="col-sm-6">
                    <label asp-for="AiotOwner" class="form-label meta-form-label">AIOT Owner</label>
                    <input asp-for="AiotOwner" class="form-control meta-input" placeholder="請輸入 AIOT 負責人" />
                </div>

                <div class="col-sm-6">
                    <label asp-for="Owner" class="form-label meta-form-label">Owner</label>
                    <input asp-for="Owner" class="form-control meta-input" placeholder="請輸入負責人" />
                </div>

                <div class="col-12">
                    <label asp-for="Schedule" class="form-label meta-form-label">Schedule</label>
                    <input asp-for="Schedule" class="form-control meta-input" placeholder="請輸入時程" />
                </div>

                <div class="col-12">
                    <label asp-for="Illustrate" class="form-label meta-form-label">Illustrate</label>
                    <textarea asp-for="Illustrate" class="form-control meta-textarea" rows="5" placeholder="請輸入補充說明"></textarea>
                </div>
            </div>

            <div class="meta-form-actions mt-4">
                <a asp-action="Index" class="btn meta-secondary-button">取消</a>
                <button type="submit" class="btn meta-primary-button">儲存</button>
            </div>
        </form>
    </div>
</div>