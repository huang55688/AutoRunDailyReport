@model AutoRunDailyReport.Models.MesMachinesMetaDto
@{
    ViewData["Title"] = $"編輯 Line：{Model.Line}";
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">

        <div class="d-flex align-items-center mb-4 gap-3">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← 返回列表</a>
            <h3 class="mb-0">@Model.Line</h3>
        </div>

        <!-- 系統計算欄位（唯讀） -->
        <div class="card mb-4 border-0 bg-light">
            <div class="card-body py-3">
                <div class="row align-items-center">
                    <div class="col-sm-4 text-muted small">1A Deadline（系統計算）</div>
                    <div class="col-sm-8 fw-semibold">
                        @if (Model.FirstADeadline.HasValue)
                        {
                            var daysLeft = (Model.FirstADeadline.Value - DateTime.Today).TotalDays;
                            var badgeClass = daysLeft < 0 ? "bg-danger"
                                           : daysLeft <= 7 ? "bg-warning text-dark"
                                           : "bg-success";
                            <span class="badge @badgeClass fs-6">
                                @Model.FirstADeadline.Value.ToString("yyyy/MM/dd")
                            </span>
                            <span class="text-muted ms-2 small">
                                @(daysLeft < 0 ? $"逾期 {(int)-daysLeft} 天"
                                               : $"還有 {(int)daysLeft} 天")
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">尚未計算（需先執行同步）</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- 手動編輯表單 -->
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Line" />

            <div class="card">
                <div class="card-body">

                    <div class="row g-3">

                        <div class="col-sm-6">
                            <label asp-for="State" class="form-label">State</label>
                            <input asp-for="State" class="form-control" placeholder="輸入狀態" />
                        </div>

                        <div class="col-sm-6">
                            <label asp-for="TestStatus" class="form-label">Test Status</label>
                            <input asp-for="TestStatus" class="form-control" placeholder="輸入測試狀態" />
                        </div>

                        <div class="col-sm-6">
                            <label asp-for="AiotOwner" class="form-label">AIOT Owner</label>
                            <input asp-for="AiotOwner" class="form-control" placeholder="輸入 AIOT 負責人" />
                        </div>

                        <div class="col-sm-6">
                            <label asp-for="Owner" class="form-label">Owner</label>
                            <input asp-for="Owner" class="form-control" placeholder="輸入負責人" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Schedule" class="form-label">Schedule</label>
                            <input asp-for="Schedule" class="form-control" placeholder="輸入排程" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Illustrate" class="form-label">Illustrate（備註說明）</label>
                            <textarea asp-for="Illustrate" class="form-control" rows="4"
                                      placeholder="輸入備註說明"></textarea>
                        </div>

                    </div>
                </div>

                <div class="card-footer d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
                    <button type="submit" class="btn btn-primary">儲存</button>
                </div>
            </div>

        </form>

    </div>
</div>
