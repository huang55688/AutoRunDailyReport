@{
    ViewData["Title"] = "同步儀表板";
}

<link rel="stylesheet" href="~/css/sync-dashboard.css" asp-append-version="true" />

<div class="container-fluid sync-page py-4">
    <div class="sync-page-header mb-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div class="sync-title-wrap">
            <span class="sync-title">同步儀表板</span>
        </div>
        <span id="runningBadge" class="sync-state-badge sync-state-idle">尚未執行</span>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="sync-panel h-100">
                <div class="sync-panel-header">
                    <div class="sync-panel-title">同步狀態</div>
                </div>
                <div class="sync-panel-body">
                    <table class="table sync-info-table mb-0">
                        <tbody>
                            <tr>
                                <td class="sync-info-label">執行狀態</td>
                                <td id="statusText">尚未執行</td>
                            </tr>
                            <tr>
                                <td class="sync-info-label">上次執行時間</td>
                                <td id="lastRunTime">-</td>
                            </tr>
                            <tr>
                                <td class="sync-info-label">上次執行訊息</td>
                                <td id="lastRunMessage">-</td>
                            </tr>
                            <tr>
                                <td class="sync-info-label">上次同步筆數</td>
                                <td id="lastRowsSynced">-</td>
                            </tr>
                            <tr>
                                <td class="sync-info-label">下次自動同步</td>
                                <td id="nextRunTime">-</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="sync-panel h-100">
                <div class="sync-panel-header">
                    <div class="sync-panel-title">操作面板</div>
                </div>
                <div class="sync-panel-body sync-action-stack">
                    <button id="syncNowBtn" class="btn sync-primary-button">
                        <span id="syncBtnText">立即同步</span>
                        <span id="syncBtnSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></span>
                    </button>

                    <div>
                        <label class="sync-form-label" for="intervalSelect">自動同步間隔</label>
                        <div class="input-group">
                            <select id="intervalSelect" class="form-select sync-select">
                                <option value="5">5 分鐘</option>
                                <option value="10">10 分鐘</option>
                                <option value="15">15 分鐘</option>
                                <option value="30" selected>30 分鐘</option>
                                <option value="60">1 小時</option>
                                <option value="120">2 小時</option>
                                <option value="480">8 小時</option>
                            </select>
                            <button id="setIntervalBtn" class="btn sync-secondary-button">更新</button>
                        </div>
                        <div id="intervalMsg" class="sync-inline-message d-none"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="sync-panel">
        <div class="sync-panel-header">
            <div class="sync-panel-title">最近同步記錄</div>
        </div>
        <div class="sync-log-wrap">
            <div class="table-responsive">
                <table class="table sync-log-table mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>時間</th>
                            <th>結果</th>
                            <th>筆數</th>
                            <th>訊息</th>
                        </tr>
                    </thead>
                    <tbody id="logsTable">
                        <tr>
                            <td colspan="4" class="sync-empty-state">目前尚無同步記錄。</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/sync-dashboard.js" asp-append-version="true"></script>
}
