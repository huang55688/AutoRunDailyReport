@model AutoRunDailyReport.Models.IpPageViewModel
@{
    ViewData["Title"] = "IP設置";
}

<link rel="stylesheet" href="~/css/ip-page.css" asp-append-version="true" />

<div class="container-fluid ip-page py-4">
    <div class="ip-page-header mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="ip-title-wrap">
                <span class="ip-title">IP設置</span>
                <div class="ip-subtitle">
                    輸入 LINEID 後，系統會從 [SM_AIOT_KF].[dbo].[MesMachinesSync] 抓取對應的
                    MESMachineNo_String / MESSubEQNo_String，並只匯入 MESMachineNo_String 為 SKL% 的資料到 [SM_AIOT_KF].[dbo].[ip]。
                </div>
            </div>
        </div>

        <form asp-action="ImportByLineId" method="post" class="ip-import-form mt-3">
            @Html.AntiForgeryToken()
            <div class="ip-import-row">
                <label for="lineId" class="ip-form-label">LINEID</label>
                <input id="lineId"
                       name="lineId"
                       type="text"
                       value="@Model.CurrentLineId"
                       class="form-control ip-line-input"
                       placeholder="請輸入 MesMachinesSync 的 MESMachineNo_String" />
                <button type="submit" class="btn ip-import-button">送出</button>
            </div>
        </form>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="ip-alert ip-alert-success mb-3">@success</div>
    }

    @if (TempData["Error"] is string error)
    {
        <div class="ip-alert ip-alert-error mb-3">@error</div>
    }

    @if (Model.Warnings.Any())
    {
        foreach (var warning in Model.Warnings)
        {
            <div class="ip-alert ip-alert-warning mb-3">@warning</div>
        }
    }

    @if (Model.HighlightedKeys.Any())
    {
        <div class="ip-alert ip-alert-highlight mb-3">
            這次剛匯入的設備已經高亮顯示，並排在表格最上方。
        </div>
    }

    <div class="ip-table-shell">
        <div class="table-responsive">
            <table class="table ip-table mb-0 align-middle">
                <thead>
                    <tr>
                        <th>LINEID</th>
                        <th>EQUIPMENTID</th>
                        <th>IP</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            var rowCssClass = Model.HighlightedKeys.Contains(item.GetRowKey())
                                ? "ip-row-highlight"
                                : string.Empty;

                            <tr class="@rowCssClass">
                                <td><code>@item.LineId</code></td>
                                <td><code>@item.EquipmentId</code></td>
                                <td>
                                    <form asp-action="SaveIp" method="post" class="ip-inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="LineId" value="@item.LineId" />
                                        <input type="hidden" name="EquipmentId" value="@item.EquipmentId" />
                                        <input type="text"
                                               name="Ip"
                                               value="@item.Ip"
                                               class="form-control ip-input"
                                               placeholder="請輸入 IP" />
                                        <button type="submit" class="btn ip-save-button">儲存</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="ip-empty-state">
                                目前 dbo.ip 還沒有資料，請先輸入 LINEID 並送出。
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
