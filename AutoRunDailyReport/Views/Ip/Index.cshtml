@model AutoRunDailyReport.Models.IpPageViewModel
@{
    ViewData["Title"] = "IP設置";
}

<link rel="stylesheet" href="~/css/ip-page.css" asp-append-version="true" />

<div class="container-fluid ip-page py-4">
    <div class="ip-page-header mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="ip-title-wrap">
                <span class="ip-title">IP設置</span>
            </div>
        </div>

        <form asp-action="SearchCandidates" method="post" class="ip-import-form mt-3">
            @Html.AntiForgeryToken()
            <div class="ip-import-row">
                <label for="lineId" class="ip-form-label">LINEID</label>
                <input id="lineId"
                       name="lineId"
                       type="text"
                       value="@Model.CurrentLineId"
                       class="form-control ip-line-input"
                       placeholder="請輸入完整或部分 MESMachineNo_String" />
                <button type="submit" class="btn ip-import-button">搜尋</button>
            </div>
        </form>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="ip-alert ip-alert-success mb-3">@success</div>
    }

    @if (TempData["Error"] is string error)
    {
        <div class="ip-alert ip-alert-error mb-3">@error</div>
    }

    @if (Model.Warnings.Any())
    {
        foreach (var warning in Model.Warnings)
        {
            <div class="ip-alert ip-alert-warning mb-3">@warning</div>
        }
    }

    @if (!string.IsNullOrWhiteSpace(Model.CurrentLineId))
    {
        <div class="ip-candidate-shell mb-4">
            <div class="ip-candidate-header">
                <div>
                    <div class="ip-section-title">候選 LINEID 清單</div>
                    <div class="ip-section-subtitle">搜尋關鍵字：<code>@Model.CurrentLineId</code></div>
                </div>
            </div>

            @if (Model.SearchCandidates.Any())
            {
                <div class="ip-candidate-list">
                    @foreach (var candidate in Model.SearchCandidates)
                    {
                        <div class="ip-candidate-row">
                            <div class="ip-candidate-info">
                                <div class="ip-candidate-code">
                                    <code>@candidate.LineId</code>
                                </div>
                                <div class="ip-candidate-meta">
                                    對應設備數：@candidate.EquipmentCount
                                </div>
                            </div>

                            <form asp-action="ImportByLineId" method="post" class="ip-candidate-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="lineId" value="@candidate.LineId" />
                                <button type="submit" class="btn ip-import-button">匯入</button>
                            </form>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="ip-empty-state ip-empty-inline">
                    找不到符合「@Model.CurrentLineId」且為 SKL% 的候選 LINEID。
                </div>
            }
        </div>
    }

    @if (Model.HighlightedKeys.Any())
    {
        <div class="ip-alert ip-alert-highlight mb-3">
            這次剛匯入的設備已經高亮顯示，並排在表格最上方。
        </div>
    }

    <div class="ip-table-shell">
        <div class="table-responsive">
            <table class="table ip-table mb-0 align-middle">
                <thead>
                    <tr>
                        <th>LINEID</th>
                        <th>EQUIPMENTID</th>
                        <th>IP</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            var rowCssClass = Model.HighlightedKeys.Contains(item.GetRowKey())
                                ? "ip-row-highlight"
                                : string.Empty;

                            <tr class="@rowCssClass">
                                <td><code>@item.LineId</code></td>
                                <td><code>@item.EquipmentId</code></td>
                                <td>
                                    <form asp-action="SaveIp" method="post" class="ip-inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="LineId" value="@item.LineId" />
                                        <input type="hidden" name="EquipmentId" value="@item.EquipmentId" />
                                        <input type="hidden" name="SearchLineId" value="@Model.CurrentLineId" />
                                        <input type="text"
                                               name="Ip"
                                               value="@item.Ip"
                                               class="form-control ip-input"
                                               placeholder="請輸入 IP" />
                                        <button type="submit" class="btn ip-save-button">儲存</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="ip-empty-state">
                                目前 dbo.ip 還沒有資料，請先搜尋候選 LINEID，再按匯入。
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
